# --- Asosiy sozlamalar ---
PORT=3000
HOST=0.0.0.0
# Sessiya kalitini ishlab chiqarishda o'zgartiring (uzun tasodifiy satr)
SESSION_SECRET=CHANGE_ME_to_a_long_random_string

# Maksimal fayl hajmi (MB)
MAX_FILE_SIZE_MB=50

# --- Til yo'nalishi ---
SOURCE_LANG=uz
TARGET_LANG=en

# --- Google Cloud Translation ---
# Bu uchtasi to'ldirilmaguncha ilova MOCK rejimda ishlaydi (faylni nusxalaydi).
# Haqiqiy tarjima uchun: Google Cloud loyihasi + Cloud Translation API + service account JSON.
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1
# Service account kalitiga to'liq yo'l, masalan: C:\Users\hasan\keys\dream-translate.json
GOOGLE_APPLICATION_CREDENTIALS=
